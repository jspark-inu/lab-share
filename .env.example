# lab-share environment variables
#
# Phase 5 skeleton — 모든 항목은 미래 child seed 에서 활성화 예정.
# 현 시점에는 비워둬도 빌드 / 배포 동작에 영향 없음.

# ---- 백엔드 API ----
# api.haiinu.com (= hai_1 FastAPI Caddy reverse proxy) 셋업 후 활성화.
# child seed 1: api.haiinu.com 백엔드 신설
#   - Cloudflare DNS CNAME api → hai_1 Tailscale funnel
#   - hai_1 Caddy: api.haiinu.com 리버스 프록시 (Socrates:8001 또는 신규 FastAPI)
#   - CORS: lab.haiinu.com origin 허용
#NEXT_PUBLIC_API_BASE=https://api.haiinu.com

# ---- 인증 ----
# child seed 2: Cloudflare Access (학생 GitHub OAuth)
#   - lab.haiinu.com + api.haiinu.com 둘 다 Access 적용
#   - 50명까지 무료, GitHub identity provider
# Access 가 활성화되면 fetch credentials:'include' 가 자동으로 CF_Authorization
# 쿠키를 보내므로 별도 client-side 환경변수 불필요.

# ---- DB / RAG / Agents ----
# child seed 3-5 에서 백엔드 측에 설정. 프론트엔드 .env 에는 반영 안 됨.
